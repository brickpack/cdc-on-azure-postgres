# Copy to .env and fill in real values. .env is gitignored -- never commit
# real credentials. No defaults below are usable as-is.

# ---------------------------------------------------------------------------
# Host / Docker Compose
# ---------------------------------------------------------------------------
# Premium SSD mount point from the VM setup (Standard_D4s_v3, /dev/sdb).
KAFKA_DATA_DIR=/kafka-data

# Hostname Kafka Connect advertises in its REST responses. Set to the VM's
# private IP or DNS name if you call the REST API from outside the VM.
CONNECT_REST_ADVERTISED_HOST_NAME=kafka-connect

# Base URL the scripts use to reach the Kafka Connect REST API.
CONNECT_URL=http://localhost:8083

# ---------------------------------------------------------------------------
# Source: Azure Database for PostgreSQL Flexible Server
# Used by deploy-postgres-source.sh to fill connectors/postgres-source.json,
# and by monitor-debezium.sh to check replication slot WAL size.
# ---------------------------------------------------------------------------
POSTGRES_HOST=PLACEHOLDER_POSTGRES_HOST
POSTGRES_PORT=5432
POSTGRES_USER=PLACEHOLDER_POSTGRES_USER
POSTGRES_PASSWORD=PLACEHOLDER_POSTGRES_PASSWORD
POSTGRES_DBNAME=PLACEHOLDER_POSTGRES_DBNAME

# Comma-separated schema.table list, e.g. public.orders,public.customers
POSTGRES_TABLE_LIST=PLACEHOLDER_POSTGRES_TABLE_LIST

# Must match an existing logical replication slot / publication (see README
# "Prerequisites"). slot.drop.on.stop=false in postgres-source.json means
# this slot is NOT cleaned up automatically -- see teardown.sh.
SLOT_NAME=PLACEHOLDER_SLOT_NAME
PUBLICATION_NAME=PLACEHOLDER_PUBLICATION_NAME

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
# monitor-debezium.sh prints a warning if replication slot WAL lag exceeds
# this many megabytes. Tune for your write volume and Premium SSD size --
# does not require editing the script.
WAL_THRESHOLD_MB=5000

# Note: original MySQL connection details (ORIGINAL_MYSQL_*) are
# deliberately NOT stored here. deploy-rollback-sink.sh takes them as
# command-line arguments at the moment of rollback, so they are never
# sitting in a file during normal idle operation.
