# One file per database instance. Copy this to instances/<name>.env (e.g.
# instances/billing.env) -- the filename (minus .env) becomes the instance
# name used throughout the pipeline: Kafka topic prefix (cdc-<name>),
# Postgres replication slot/publication (cdc_<name>), connector names
# (postgres-source-<name>, mysql-rollback-sink-<name>), and the Key
# Vault-style secret path used by the Kafka Connect DirectoryConfigProvider
# (cdc-<name>-postgres-password).
#
# instances/*.env is gitignored -- only this .env.example template is
# tracked. INSTANCE_NAME must match the filename; scripts use it to name
# connectors/topics/secrets and will refuse to run if it doesn't match.

INSTANCE_NAME=example

# This instance's Postgres Flexible Server (the post-cutover system of
# record for this database).
POSTGRES_HOST=PLACEHOLDER.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_USER=cdc_replication
POSTGRES_PASSWORD=PLACEHOLDER_REPLICATION_PASSWORD
POSTGRES_DBNAME=PLACEHOLDER_DBNAME

# Replication slot + publication created in this instance's "Prerequisites"
# step. Convention: cdc_<name> (must be a valid Postgres identifier -- no
# hyphens).
SLOT_NAME=cdc_example
PUBLICATION_NAME=cdc_example
