# Copy to terraform.tfvars (gitignored) and fill in.
#
#   az account show --query id -o tsv
#   curl -s https://ifconfig.me
#
# Full deploy sequence (Terraform → Strimzi → Helm): see README.md
#
subscription_id = "00000000-0000-0000-0000-000000000000"

# name_prefix  = "cdc"
# location     = "westus2"

# Defaults are D2ds_v4 (fits ~10 vCPU DDSv4 / regional quota). Prefer D4ds_v4
# for CDC once Total Regional + DDSv4 family quotas are >= 20 in the region:
#   cdc_node_vm_size = "Standard_D4ds_v4"

api_server_authorized_ip_ranges = [
  "YOUR.PUBLIC.IP.HERE/32",
]

# Existing Key Vault that already holds Postgres/MySQL passwords. This module
# does not create a vault -- it only grants the AKS CSI identity read access.
key_vault_name                = "dbmig-dev-kv"
key_vault_resource_group_name = "dbmig-dev-rg"

# Peer to the VNet hosting Postgres + MySQL Flexible Servers (local half only).
# After apply, create the remote peering half and link private DNS zones to
# the AKS VNet -- see README.md step 7.
# peer_vnet_ids = [
#   "/subscriptions/.../resourceGroups/.../providers/Microsoft.Network/virtualNetworks/...",
# ]
