# Copy to .env and fill in real values. This file holds settings SHARED by
# the whole Docker Compose stack (one Kafka + one Kafka Connect worker for
# every instance). Per-database connection details (Postgres host, slot
# name, publication, etc.) do NOT go here -- each database gets its own file
# under instances/, copied from instances/example.env.example.

# Kafka Connect REST API, as seen from this host (used by scripts/*.sh).
CONNECT_URL=http://localhost:8083

# Stable cluster ID for KRaft mode. Generate once with:
#   docker run --rm confluentinc/cp-kafka:7.5.0 kafka-storage random-uuid
# If the data dir already exists with a different ID, delete it first
# (docker compose down -v) before changing this.
KAFKA_CLUSTER_ID=$KAFKA_CLUSTER_ID

# Host path where Kafka's data directory is stored (persists topics across
# container restarts).
KAFKA_DATA_DIR=/kafka-data

# Advertised hostname for the Kafka Connect REST API. Leave as kafka-connect
# unless you're reaching it from outside the Docker network under a
# different name.
CONNECT_REST_ADVERTISED_HOST_NAME=kafka-connect

# WAL lag (in MB) above which scripts/cdc-status.sh and
# scripts/monitor-debezium.sh report a warning, per instance.
WAL_THRESHOLD_MB=5000
