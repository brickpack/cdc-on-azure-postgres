MYSQL_FQDN=<mysql db instance>.mysql.database.azure.com
MYSQL_USER=migrate_admin
MYSQL_DB=<source db>
PG_FQDN=<the db instance>.postgres.database.azure.com
PG_USER=<app owner user>
PG_DB=<target db>
PG_SCHEMA=<target schema, e.g. public or desktop>

# ── pg_chameleon tuning (all optional — shown values are defaults) ──
# export CHAMELEON_COPY_MAX_MEMORY=300M        # RAM per table during init_replica (docs recommend 300M)
# export CHAMELEON_MEMORY_LIMIT=1g             # Docker container memory limit — must be > 2x COPY_MAX_MEMORY; exit 137 = OOM kill
# export CHAMELEON_REPLICA_BATCH_SIZE=10000     # rows per batch during read
# export CHAMELEON_REPLAY_MAX_ROWS=10000        # rows per batch during replay
# export CHAMELEON_BATCH_RETENTION="3 days"     # how long to keep batch data for debugging
# export CHAMELEON_COPY_MODE=file               # 'file' (default) or 'direct'
# export CHAMELEON_GTID_ENABLE=true             # must match MySQL gtid_mode (ON→true)
# export CHAMELEON_ON_ERROR_REPLAY=exit         # 'exit' (safe) or 'continue' (skip errors silently)
# export CHAMELEON_ON_ERROR_READ=exit           # 'exit' (safe) or 'continue'
# export CHAMELEON_AUTO_MAINTENANCE=disabled    # 'disabled' or PostgreSQL interval e.g. '1 day'
# export CHAMELEON_LOG_LEVEL=info               # debug, info, warning, error
# export CHAMELEON_NET_READ_TIMEOUT=3600        # MySQL net_read_timeout in seconds
# export CHAMELEON_NET_WRITE_TIMEOUT=3600       # MySQL net_write_timeout in seconds
# export CHAMELEON_WAIT_TIMEOUT=28800           # MySQL wait_timeout in seconds
